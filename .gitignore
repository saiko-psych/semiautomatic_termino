# ===========================================================================
# Termino-Skript .gitignore
# ===========================================================================
# Goal: keep per-lab configuration, per-day runtime state, secrets, and
# personal templates OUT of git. Only generic, sharable files belong here.

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.venv/
venv/

# --- Environment / secrets ---
sensible.env
sensible.env.*
.env
.env.local

# --- Runtime state (per-day, NEVER commit) ---
status.json
status.json.bak*
session.json
data/
debug_termino/

# --- Per-lab configuration (each install has its own) ---
config.json
config.backup.*.json
config.tmp.json
config.pretty.json

# --- Per-lab e-mail templates (each install customizes its own) ---
templates/first_email.txt
templates/reminder.txt

# --- Temporary template files / Excel backups ---
templates/versuchsleiter.backup.*.xlsx
templates/versuchsleiter.new.xlsx
templates/versuchsleiter.current.xlsx

# --- Dev workflow files (local-only) ---
NEXT_COMMIT.md
bug_fixing.py
tools/prepare_for_github.ps1
tools/finalize_v2_release.ps1

# --- General backup catch-all ---
*.bak
*.bak-*

# --- IDE ---
.vscode/
.idea/
*.swp
.spyderproject
.spyproject

# --- OS ---
.DS_Store
Thumbs.db

# --- Test artefacts ---
.pytest_cache/
.coverage
htmlcov/

# --- v1 dead code (replaced in v2: config.py -> setup.py; requirements.txt -> pyproject.toml + uv.lock) ---
config.py
requirements.txt

# --- Lab-specific spreadsheet (each install has its own versuchsleiter.xlsx) ---
templates/versuchsleiter.xlsx

# --- Deployment-Plan (lab-specific, do not push) ---
SERVER_DEPLOY_PLAN.md

# --- Patch bundle (local-only, applied then deleted) ---
.patches/

# === Personal / internal notes � NEVER commit ===
CLAUDE.md
NEXT_COMMIT.md
docs/UNIGRAZ_OPENCONNECT_ROADMAP.md
docs/AUTO-VPN-TEST-REPORT.md
COWORK_PROMPT*.md

# Working preferences / status files
STATUS.md
TESTING.md

# Backup files
*.bak
*.bak*

# === Personal / internal notes — NEVER commit ===
# These files contain workflow preferences, status, internal architecture
# notes, and quoted email correspondence with uniIT. They stay LOCAL only.
CLAUDE.md
NEXT_COMMIT.md
STATUS.md
TESTING.md
COWORK_PROMPT*.md

# Internal docs with account-specific identifiers
docs/SERVER_VPN_SETUP.md
docs/UNIGRAZ_OPENCONNECT_ROADMAP.md
docs/AUTO-VPN-TEST-REPORT.md

# Backup files
*.bak
*.bak*
# Sandbox / dev-environment recovery scripts — internal only
git_setup.ps1
repair.ps1
# Sandbox / dev-environment recovery scripts (internal only)
git_setup.ps1
repair.ps1

# Sphinx / Read the Docs build output
docs/_build/
docs/reference/api/generated/
# autosummary :toctree: generated stubs anywhere under docs/ (incl. stray ones
# produced from example blocks in planning docs)
docs/**/generated/